# PostgreSQL connection string
# Local (Docker): postgresql://postgres:postgres@localhost:5432/floci_trainer
# Railway: provided automatically via ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/floci_trainer

# Port (Railway injects this automatically; leave default for local)
PORT=3000

# Floci (AWS emulator) endpoint
# Local (Docker Compose): http://localhost:4566
# Railway (internal network): http://floci.railway.internal:4566
FLOCI_ENDPOINT=http://localhost:4566
