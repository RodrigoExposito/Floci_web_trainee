# PostgreSQL connection string
# Local (Docker): postgresql://postgres:postgres@localhost:5432/floci_trainer
# Railway: provided automatically via ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/floci_trainer

# Port (Railway injects this automatically; leave default for local)
PORT=3000

# Floci (AWS emulator) endpoint
# Local (Docker Compose): http://localhost:4566
# Railway (internal network): http://floci.railway.internal:4566
FLOCI_ENDPOINT=http://localhost:4566

# Groq API key — used by the AI assistant (POST /api/ai/chat)
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# JWT secret — used to sign and verify user tokens
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins for CORS
# If unset, all origins are allowed (dev mode).
# Example: https://floci-web.up.railway.app
ALLOWED_ORIGINS=
